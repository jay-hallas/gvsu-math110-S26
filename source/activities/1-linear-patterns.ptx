<?xml version="1.0" encoding="UTF-8"?>
<worksheet xml:id="activity-visual-patterns"
  xmlns:xi="http://www.w3.org/2001/XInclude">

  <title>Activity: Visual Patterns</title>

  <introduction>
    <p>
      For each of the following patterns, complete the following steps:
      <ul>
        <li><p>Draw Case 4 and Case 5.</p></li>
        <li><p>Complete the table.</p></li>
        <li><p>Determine whether the growth is <em>linear</em> and explain how you know.</p></li>
        <li><p>If linear, find an equation for the number of blocks (<m>y</m>) in terms of the
        case number (<m>n</m>).</p></li>
        <li><p>Check that your equation works by plugging in some cases from the table to see
        that they match.</p></li>
      </ul>
    </p>
  </introduction>

  <!-- ===================================================
       PAGE 1: Pattern 1 (U-shape, blue blocks) and Pattern 2 (grid circles)
       =================================================== -->
  <page>

    <exercise xml:id="ex-pattern-1">
      <title>Pattern 1</title>
      <introduction>
        <figure xml:id="fig-pattern-1">
          <caption>
            A U-shaped block pattern. Case 1 has a row of 3 blocks across the top with 1 block
            hanging below each end (5 total). Each subsequent case adds one block to each of
            the two side columns.
          </caption>
          <image xml:id="img-pattern-1" width="85%">
            <shortdescription>
              Three completed U-shaped block figures for Cases 1, 2, and 3, followed by two
              dashed empty boxes for students to draw Cases 4 and 5.
            </shortdescription>
            <latex-image>
              \begin{tikzpicture}[scale=0.34, baseline]
                % Case 1
                \begin{scope}[shift={(0,0)}]
                  \foreach \x in {0,1,2} \draw[fill=blue!70, draw=black, thick] (\x,0) rectangle ++(1,1);
                  \draw[fill=blue!70, draw=black, thick] (0,-1) rectangle ++(1,1);
                  \draw[fill=blue!70, draw=black, thick] (2,-1) rectangle ++(1,1);
                  \node at (1.5,-2.0) {Case 1};
                \end{scope}
                % Case 2
                \begin{scope}[shift={(5.2,0)}]
                  \foreach \x in {0,1,2} \draw[fill=blue!70, draw=black, thick] (\x,0) rectangle ++(1,1);
                  \foreach \y in {-1,-2} {
                    \draw[fill=blue!70, draw=black, thick] (0,\y) rectangle ++(1,1);
                    \draw[fill=blue!70, draw=black, thick] (2,\y) rectangle ++(1,1);
                  }
                  \node at (1.5,-3.0) {Case 2};
                \end{scope}
                % Case 3
                \begin{scope}[shift={(10.4,0)}]
                  \foreach \x in {0,1,2} \draw[fill=blue!70, draw=black, thick] (\x,0) rectangle ++(1,1);
                  \foreach \y in {-1,-2,-3} {
                    \draw[fill=blue!70, draw=black, thick] (0,\y) rectangle ++(1,1);
                    \draw[fill=blue!70, draw=black, thick] (2,\y) rectangle ++(1,1);
                  }
                  \node at (1.5,-4.0) {Case 3};
                \end{scope}
                % Case 4 (blank)
                \begin{scope}[shift={(15.8,0)}]
                  \draw[dashed, gray] (-0.4,-6.0) rectangle (4.4,1.6);
                  \node at (2.0,-6.8) {Case 4};
                \end{scope}
                % Case 5 (blank)
                \begin{scope}[shift={(21.0,0)}]
                  \draw[dashed, gray] (-0.4,-6.0) rectangle (4.4,1.6);
                  \node at (2.0,-6.8) {Case 5};
                \end{scope}
              \end{tikzpicture}
            </latex-image>
          </image>
        </figure>
      </introduction>

      <task xml:id="ex-pattern-1-table">
        <statement>
          <p>Complete the table.</p>
          <tabular halign="center" top="major" bottom="major" left="minor" right="minor">
            <row header="yes" bottom="minor">
              <cell>Case (<m>n</m>)</cell>
              <cell>1</cell><cell>2</cell><cell>3</cell><cell>4</cell><cell>5</cell>
            </row>
            <row>
              <cell>Shapes</cell>
              <cell>5</cell><cell>7</cell><cell>9</cell><cell></cell><cell></cell>
            </row>
          </tabular>
        </statement>
      </task>

      <task xml:id="ex-pattern-1-linear" workspace="0.9cm">
        <statement>
          <p>
            Is the growth <em>linear</em>? Circle one: <em>Yes</em> / <em>No</em>. Explain how
            you know.
          </p>
        </statement>
      </task>

      <task xml:id="ex-pattern-1-equation" workspace="0.9cm">
        <statement>
          <p>
            If linear, write an equation for the number of shapes <m>y</m> in terms of the case
            number <m>n</m>. Then check your equation using at least two values from the table.
          </p>
          <p><em>Equation:</em> <fillin characters="30"/></p>
        </statement>
      </task>
    </exercise>

    <exercise xml:id="ex-pattern-2">
      <title>Pattern 2</title>
      <introduction>
        <figure xml:id="fig-pattern-2">
          <caption>
            A rectangular grid of circles. Case 1 is a single column of 3 circles, Case 2 is a
            2-by-3 grid (6 circles), Case 3 is a 3-by-3 grid (9 circles).
          </caption>
          <image xml:id="img-pattern-2" width="85%">
            <shortdescription>
              Three completed grids of green circles for Cases 1, 2, and 3, followed by two
              dashed empty boxes for students to draw Cases 4 and 5.
            </shortdescription>
            <latex-image>
              \begin{tikzpicture}[scale=0.34, baseline]
                % Case 1
                \begin{scope}[shift={(0,0)}]
                  \foreach \y in {0,1,2}
                    \node[draw, circle, fill=green!70, thick, minimum size=3mm, inner sep=0pt]
                      at (0.5,\y+0.5) {};
                  \node at (0.5,-1.0) {Case 1};
                \end{scope}
                % Case 2
                \begin{scope}[shift={(4.5,0)}]
                  \foreach \x in {0,1} \foreach \y in {0,1,2}
                    \node[draw, circle, fill=green!70, thick, minimum size=3mm, inner sep=0pt]
                      at (\x+0.5,\y+0.5) {};
                  \node at (1.0,-1.0) {Case 2};
                \end{scope}
                % Case 3
                \begin{scope}[shift={(9.6,0)}]
                  \foreach \x in {0,1,2} \foreach \y in {0,1,2}
                    \node[draw, circle, fill=green!70, thick, minimum size=3mm, inner sep=0pt]
                      at (\x+0.5,\y+0.5) {};
                  \node at (1.5,-1.0) {Case 3};
                \end{scope}
                % Case 4 (blank)
                \begin{scope}[shift={(14.9,0)}]
                  \draw[dashed, gray] (-0.4,-0.4) rectangle (4.8,4.4);
                  \node at (2.0,-1.0) {Case 4};
                \end{scope}
                % Case 5 (blank)
                \begin{scope}[shift={(21.0,0)}]
                  \draw[dashed, gray] (-0.4,-0.4) rectangle (5.8,4.4);
                  \node at (2.5,-1.0) {Case 5};
                \end{scope}
              \end{tikzpicture}
            </latex-image>
          </image>
        </figure>
      </introduction>

      <task xml:id="ex-pattern-2-table">
        <statement>
          <p>Complete the table.</p>
          <tabular halign="center" top="major" bottom="major" left="minor" right="minor">
            <row header="yes" bottom="minor">
              <cell>Case (<m>n</m>)</cell>
              <cell>1</cell><cell>2</cell><cell>3</cell><cell>4</cell><cell>5</cell>
            </row>
            <row>
              <cell>Shapes</cell>
              <cell>3</cell><cell>6</cell><cell>9</cell><cell></cell><cell></cell>
            </row>
          </tabular>
        </statement>
      </task>

      <task xml:id="ex-pattern-2-linear" workspace="0.9cm">
        <statement>
          <p>
            Is the growth <em>linear</em>? Circle one: <em>Yes</em> / <em>No</em>. Explain how
            you know.
          </p>
        </statement>
      </task>

      <task xml:id="ex-pattern-2-equation" workspace="0.9cm">
        <statement>
          <p>
            If linear, write an equation for the number of shapes <m>y</m> in terms of the case
            number <m>n</m>. Then check your equation using at least two values from the table.
          </p>
          <p><em>Equation:</em> <fillin characters="30"/></p>
        </statement>
      </task>
    </exercise>

  </page>

  <!-- ===================================================
       PAGE 2: Pattern 3 (stars, square) and Pattern 4 (triangles, staircase)
       =================================================== -->
  <page>

    <exercise xml:id="ex-pattern-3">
      <title>Pattern 3</title>
      <introduction>
        <figure xml:id="fig-pattern-3">
          <caption>
            A square grid of stars. Case 1 has 1 star, Case 2 has a 2-by-2 grid (4 stars),
            Case 3 has a 3-by-3 grid (9 stars).
          </caption>
          <image xml:id="img-pattern-3" width="85%">
            <shortdescription>
              Three completed square grids of teal five-pointed stars for Cases 1, 2, and 3,
              followed by two dashed empty boxes for Cases 4 and 5.
            </shortdescription>
            <latex-image>
              \usetikzlibrary{shapes.geometric}
              \begin{tikzpicture}[scale=0.30, baseline]
                % Case 1
                \begin{scope}[shift={(0,0)}]
                  \node[star, star points=5, draw=black, fill=teal!70, thick,
                        minimum size=3mm, inner sep=0pt] at (0.5,0.5) {};
                  \node at (0.5,-1.0) {Case 1};
                \end{scope}
                % Case 2
                \begin{scope}[shift={(3.6,0)}]
                  \foreach \x in {0,1} \foreach \y in {0,1}
                    \node[star, star points=5, draw=black, fill=teal!70, thick,
                          minimum size=3mm, inner sep=0pt] at (\x+0.5,\y+0.5) {};
                  \node at (1.0,-1.0) {Case 2};
                \end{scope}
                % Case 3
                \begin{scope}[shift={(8.1,0)}]
                  \foreach \x in {0,1,2} \foreach \y in {0,1,2}
                    \node[star, star points=5, draw=black, fill=teal!70, thick,
                          minimum size=3mm, inner sep=0pt] at (\x+0.5,\y+0.5) {};
                  \node at (1.5,-1.0) {Case 3};
                \end{scope}
                % Case 4 (blank)
                \begin{scope}[shift={(14.1,0)}]
                  \draw[dashed, gray] (-0.4,-0.4) rectangle (4.4,4.4);
                  \node at (2.0,-1.0) {Case 4};
                \end{scope}
                % Case 5 (blank)
                \begin{scope}[shift={(20.5,0)}]
                  \draw[dashed, gray] (-0.4,-0.4) rectangle (5.4,5.4);
                  \node at (2.5,-1.0) {Case 5};
                \end{scope}
              \end{tikzpicture}
            </latex-image>
          </image>
        </figure>
      </introduction>

      <task xml:id="ex-pattern-3-table">
        <statement>
          <p>Complete the table.</p>
          <tabular halign="center" top="major" bottom="major" left="minor" right="minor">
            <row header="yes" bottom="minor">
              <cell>Case (<m>n</m>)</cell>
              <cell>1</cell><cell>2</cell><cell>3</cell><cell>4</cell><cell>5</cell>
            </row>
            <row>
              <cell>Shapes</cell>
              <cell>1</cell><cell>4</cell><cell>9</cell><cell></cell><cell></cell>
            </row>
          </tabular>
        </statement>
      </task>

      <task xml:id="ex-pattern-3-linear" workspace="0.9cm">
        <statement>
          <p>
            Is the growth <em>linear</em>? Circle one: <em>Yes</em> / <em>No</em>. Explain how
            you know.
          </p>
        </statement>
      </task>

      <task xml:id="ex-pattern-3-equation" workspace="0.9cm">
        <statement>
          <p>
            If linear, write an equation for the number of shapes <m>y</m> in terms of the case
            number <m>n</m>. Then check your equation using at least two values from the table.
          </p>
          <p><em>Equation:</em> <fillin characters="30"/></p>
        </statement>
      </task>
    </exercise>

   <exercise xml:id="ex-pattern-4">
      <title>Pattern 4</title>
      <introduction>
        <figure xml:id="fig-pattern-4">
          <caption>
            A staircase arrangement of triangles. Case 1 has a bottom row of 2 triangles with
            1 triangle above (3 total). Each subsequent case adds one triangle to the bottom row
            and one triangle to the row above, growing the staircase by 2 each time.
          </caption>
          <image xml:id="img-pattern-4" width="90%">
            <shortdescription>
              Three staircase arrangements of purple triangles for Cases 1, 2, and 3, followed
              by two dashed empty boxes for Cases 4 and 5.
            </shortdescription>
            <latex-image>
              \usetikzlibrary{shapes.geometric}
              \begin{tikzpicture}[scale=0.34, baseline]
                % Case 1: bottom row 2, top row 1 (total 3)
                \begin{scope}[shift={(0,0)}]
                  \foreach \x in {0,1}
                    \node[regular polygon, regular polygon sides=3, draw=black, fill=purple!70, thick,
                          minimum size=3mm, inner sep=0pt] at (\x+0.5,0.5) {};
                  \node[regular polygon, regular polygon sides=3, draw=black, fill=purple!70, thick,
                        minimum size=3mm, inner sep=0pt] at (0.5,1.5) {};
                  \node at (0.5,-1.0) {Case 1};
                \end{scope}
                % Case 2: bottom row 3, row2 2 (total 5)
                \begin{scope}[shift={(4.8,0)}]
                  \foreach \x in {0,1,2}
                    \node[regular polygon, regular polygon sides=3, draw=black, fill=purple!70, thick,
                          minimum size=3mm, inner sep=0pt] at (\x+0.5,0.5) {};
                  \foreach \x in {0,1}
                    \node[regular polygon, regular polygon sides=3, draw=black, fill=purple!70, thick,
                          minimum size=3mm, inner sep=0pt] at (\x+0.5,1.5) {};
                  \node at (1.5,-1.0) {Case 2};
                \end{scope}
                % Case 3: bottom row 4, row2 3 (total 7)
                \begin{scope}[shift={(10.1,0)}]
                  \foreach \x in {0,1,2,3}
                    \node[regular polygon, regular polygon sides=3, draw=black, fill=purple!70, thick,
                          minimum size=3mm, inner sep=0pt] at (\x+0.5,0.5) {};
                  \foreach \x in {0,1,2}
                    \node[regular polygon, regular polygon sides=3, draw=black, fill=purple!70, thick,
                          minimum size=3mm, inner sep=0pt] at (\x+0.5,1.5) {};
                  \node at (2.0,-1.0) {Case 3};
                \end{scope}
                % Case 4 (blank)
                \begin{scope}[shift={(15.7,0)}]
                  \draw[dashed, gray] (-0.4,-0.4) rectangle (5.8,5.8);
                  \node at (2.5,-1.0) {Case 4};
                \end{scope}
                % Case 5 (blank)
                \begin{scope}[shift={(22.8,0)}]
                  \draw[dashed, gray] (-0.4,-0.4) rectangle (6.8,6.8);
                  \node at (3.0,-1.0) {Case 5};
                \end{scope}
              \end{tikzpicture}
            </latex-image>
          </image>
        </figure>
      </introduction>

      <task xml:id="ex-pattern-4-table">
        <statement>
          <p>Complete the table.</p>
          <tabular halign="center" top="major" bottom="major" left="minor" right="minor">
            <row header="yes" bottom="minor">
              <cell>Case (<m>n</m>)</cell>
              <cell>1</cell><cell>2</cell><cell>3</cell><cell>4</cell><cell>5</cell>
            </row>
            <row>
              <cell>Shapes</cell>
              <cell>3</cell><cell>5</cell><cell>7</cell><cell></cell><cell></cell>
            </row>
          </tabular>
        </statement>
      </task>

      <task xml:id="ex-pattern-4-linear" workspace="0.9cm">
        <statement>
          <p>
            Is the growth <em>linear</em>? Circle one: <em>Yes</em> / <em>No</em>. Explain how
            you know.
          </p>
        </statement>
      </task>

      <task xml:id="ex-pattern-4-equation" workspace="0.9cm">
        <statement>
          <p>
            If linear, write an equation for the number of shapes <m>y</m> in terms of the case
            number <m>n</m>. Then check your equation using at least two values from the table.
          </p>
          <p><em>Equation:</em> <fillin characters="30"/></p>
        </statement>
      </task>
    </exercise>

  </page>

  <!-- ===================================================
       PAGE 3: Pattern 5 (hexagons, staircase)
       =================================================== -->
  <page>

    <exercise xml:id="ex-pattern-5">
      <title>Pattern 5</title>
      <introduction>
        <figure xml:id="fig-pattern-5">
          <caption>
            A growing arrangement of hexagons. Case 1 has 5 hexagons in a single row. Case 2
            adds a second row of 4 hexagons above (9 total). Case 3 adds a third row of 4
            hexagons (13 total).
          </caption>
          <image xml:id="img-pattern-5" width="90%">
            <shortdescription>
              Three arrangements of brick-red hexagons for Cases 1, 2, and 3, followed by two
              dashed empty boxes for Cases 4 and 5.
            </shortdescription>
            <latex-image>
              \usetikzlibrary{shapes.geometric}
              \begin{tikzpicture}[scale=0.30, baseline]
                % Case 1: 5 hexagons in a row
                \begin{scope}[shift={(0,0)}]
                  \foreach \x in {0,1,2,3,4}
                    \node[regular polygon, regular polygon sides=6, draw=black, fill=red!70, thick,
                          minimum size=3mm, inner sep=0pt] at (\x+0.5,0.5) {};
                  \node at (2.5,-1.0) {Case 1};
                \end{scope}
                % Case 2: bottom row 5, row2 4
                \begin{scope}[shift={(6.5,0)}]
                  \foreach \x in {0,1,2,3,4}
                    \node[regular polygon, regular polygon sides=6, draw=black, fill=red!70, thick,
                          minimum size=3mm, inner sep=0pt] at (\x+0.5,0.5) {};
                  \foreach \x in {0,1,2,3}
                    \node[regular polygon, regular polygon sides=6, draw=black, fill=red!70, thick,
                          minimum size=3mm, inner sep=0pt] at (\x+0.5,1.5) {};
                  \node at (2.5,-1.0) {Case 2};
                \end{scope}
                % Case 3: bottom row 5, row2 4, row3 4
                \begin{scope}[shift={(14.0,0)}]
                  \foreach \x in {0,1,2,3,4}
                    \node[regular polygon, regular polygon sides=6, draw=black, fill=red!70, thick,
                          minimum size=3mm, inner sep=0pt] at (\x+0.5,0.5) {};
                  \foreach \x in {0,1,2,3}
                    \node[regular polygon, regular polygon sides=6, draw=black, fill=red!70, thick,
                          minimum size=3mm, inner sep=0pt] at (\x+0.5,1.5) {};
                  \foreach \x in {0,1,2,3}
                    \node[regular polygon, regular polygon sides=6, draw=black, fill=red!70, thick,
                          minimum size=3mm, inner sep=0pt] at (\x+0.5,2.5) {};
                  \node at (2.5,-1.0) {Case 3};
                \end{scope}
                % Case 4 (blank)
                \begin{scope}[shift={(23.0,0)}]
                  \draw[dashed, gray] (-0.4,-0.4) rectangle (5.4,5.4);
                  \node at (2.5,-1.0) {Case 4};
                \end{scope}
                % Case 5 (blank)
                \begin{scope}[shift={(31.0,0)}]
                  \draw[dashed, gray] (-0.4,-0.4) rectangle (5.4,5.4);
                  \node at (2.5,-1.0) {Case 5};
                \end{scope}
              \end{tikzpicture}
            </latex-image>
          </image>
        </figure>
      </introduction>

      <task xml:id="ex-pattern-5-table">
        <statement>
          <p>Complete the table.</p>
          <tabular halign="center" top="major" bottom="major" left="minor" right="minor">
            <row header="yes" bottom="minor">
              <cell>Case (<m>n</m>)</cell>
              <cell>1</cell><cell>2</cell><cell>3</cell><cell>4</cell><cell>5</cell>
            </row>
            <row>
              <cell>Shapes</cell>
              <cell>5</cell><cell>9</cell><cell>13</cell><cell></cell><cell></cell>
            </row>
          </tabular>
        </statement>
      </task>

      <task xml:id="ex-pattern-5-linear" workspace="0.9cm">
        <statement>
          <p>
            Is the growth <em>linear</em>? Circle one: <em>Yes</em> / <em>No</em>. Explain how
            you know.
          </p>
        </statement>
      </task>

      <task xml:id="ex-pattern-5-equation" workspace="0.9cm">
        <statement>
          <p>
            If linear, write an equation for the number of shapes <m>y</m> in terms of the case
            number <m>n</m>. Then check your equation using at least two values from the table.
          </p>
          <p><em>Equation:</em> <fillin characters="30"/></p>
        </statement>
      </task>
    </exercise>

  </page>

</worksheet>
